DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=
POSTGRES_DB=ai_hr_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
MEDIA_ROOT=media
MEDIA_URL=/media/

# ─── Production reference (HireParrot.com) ────────────────────────────────
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=hireparrot.com,www.hireparrot.com,wayne-ai-hr.vercel.app,64.227.150.115
# CORS_ALLOWED_ORIGINS=https://hireparrot.com,https://www.hireparrot.com,https://wayne-ai-hr.vercel.app
# PDF_VERIFY_BASE_URL=https://hireparrot.com/verify
# PDF_VERIFY_SECRET=<long-random-string>     # required so signing survives restarts
#
# AWS SES via django-ses (uses boto3 + IAM keys — same as S3, no separate
# SES SMTP credentials needed). The IAM user must have ses:SendEmail and
# ses:SendRawEmail in its policy, and the sending identity (hireparrot.com)
# must be verified in AWS_SES_REGION_NAME.
# AWS_ACCESS_KEY_ID=<your-iam-access-key-id>
# AWS_SECRET_ACCESS_KEY=<your-iam-secret>
# AWS_SES_REGION_NAME=us-east-1
# DEFAULT_FROM_EMAIL=HireParrot <hello@hireparrot.com>
# DEMO_NOTIFY_EMAIL=hello@hireparrot.com
# AUTOREPLY_FROM_EMAIL=HireParrot <noreply@hireparrot.com>     # auto-replies use this
