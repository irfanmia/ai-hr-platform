# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=<SES SMTP username, NOT IAM access key>
# EMAIL_HOST_PASSWORD=<SES SMTP password>
# DEFAULT_FROM_EMAIL=HireParrot <hello@hireparrot.com>
# DEMO_NOTIFY_EMAIL=hello@hireparrot.com
